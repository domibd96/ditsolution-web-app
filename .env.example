# Port (optional, default: 3001)
PORT=3001

# IONOS SMTP – E-Mails werden von info@ditsolution.de versendet
# 1. IONOS Kundenbereich → E-Mail → Postfach info@ditsolution.de
# 2. Passwort = dein Postfach-Passwort (kein App-Passwort nötig wie bei Gmail)
# 3. Server: smtp.ionos.de, Port 587 (STARTTLS) oder 465 (SSL)
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=info@ditsolution.de
SMTP_PASS=dein-postfach-passwort

# Optional: An diese Adresse gehen eingehende Kontaktanfragen (Standard = SMTP_USER)
# CONTACT_EMAIL=info@ditsolution.de
