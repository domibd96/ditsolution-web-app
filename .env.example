# Port (optional, default: 3001)
PORT=3001

# STRATO SMTP – E-Mails werden von info@ditsolution.de versendet
# Server: smtp.strato.de
# Port: 465 (SSL/TLS)
SMTP_HOST=smtp.strato.de
SMTP_PORT=465
SMTP_USER=info@ditsolution.de
SMTP_PASS=dein-strato-postfach-passwort

# Optional: An diese Adresse gehen eingehende Kontaktanfragen (Standard = SMTP_USER)
# CONTACT_EMAIL=info@ditsolution.de
